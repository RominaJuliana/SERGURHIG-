<script>
  /* ── TABS ── */
  function openTab(tab) {
    document.querySelectorAll('.tab-btn').forEach((b,i) => {
      const ids = ['quienes','misionvision','servicios','contacto'];
      b.classList.toggle('active', ids[i] === tab);
    });
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    const el = document.getElementById('panel-' + tab);
    if(el) {
      el.classList.add('active');
      document.querySelector('.tabs-wrapper').scrollIntoView({behavior:'smooth', block:'start'});
    }
  }

  /* ── SERVICES FILTER ── */
  function filterServ(cat, btn) {
    document.querySelectorAll('.sf-btn').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    document.querySelectorAll('.serv-card').forEach(c => {
      c.classList.toggle('hide', cat !== 'all' && c.dataset.c !== cat);
    });
  }

  /* ── FORM → EMAIL via mailto ── */
  function enviarFormulario() {
    const nombre   = document.getElementById('c-nombre').value.trim();
    const email    = document.getElementById('c-email').value.trim();
    const empresa  = document.getElementById('c-empresa').value.trim();
    const tel      = document.getElementById('c-tel').value.trim();
    const servicio = document.getElementById('c-servicio').value;
    const consulta = document.getElementById('c-consulta').value.trim();

    if (!nombre || !email || !consulta) {
      alert('Por favor completá los campos obligatorios: Nombre, Correo y Consulta.');
      return;
    }

    const subject = encodeURIComponent('Consulta desde Sergurigh.com – ' + nombre);
    const body = encodeURIComponent(
      'Nombre: ' + nombre + '\n' +
      'Email: ' + email + '\n' +
      (empresa ? 'Empresa: ' + empresa + '\n' : '') +
      (tel ? 'Teléfono: ' + tel + '\n' : '') +
      (servicio ? 'Servicio de interés: ' + servicio + '\n' : '') +
      '\nConsulta:\n' + consulta
    );

    // Abre cliente de correo con mailto
    window.location.href = 'mailto:sergurigh@gmail.com?subject=' + subject + '&body=' + body;

    // También ofrece envío por WhatsApp como alternativa
    const waMsg = encodeURIComponent(
      '👋 Hola Romina, te contacto desde tu web:\n\n' +
      '👤 Nombre: ' + nombre + '\n' +
      '📧 Email: ' + email +
      (empresa ? '\n🏢 Empresa: ' + empresa : '') +
      (servicio ? '\n🛡️ Servicio: ' + servicio : '') +
      '\n\n💬 Consulta:\n' + consulta
    );

    // Mostrar mensaje de éxito
    setTimeout(() => {
      const msg = document.getElementById('success-msg');
      msg.style.display = 'block';
      // ofrecer WA alternativo
      msg.innerHTML = '✅ ¡Se abrió tu cliente de correo! También podés <a href="https://wa.me/5493446662925?text=' + waMsg + '" target="_blank" style="color:var(--gold);font-weight:600">enviar por WhatsApp</a> si preferís.';
    }, 500);
  }
